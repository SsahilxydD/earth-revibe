auto-install-peers=true
strict-peer-dependencies=false
# Don't block on the interactive "node_modules will be reinstalled" prompt
# when hoisting config changes. Safe for monorepos where the reinstall is
# idempotent.
confirm-modules-purge=false

# Expo + Metro + Babel walk node_modules from deep .pnpm paths and need
# transitive deps reachable at the project root or one level up. Selective
# hoisting kept missing peer-of-peer packages (react-native-worklets,
# @expo/metro-runtime, react-native-css-interop, ...). Hoisting everything
# is equivalent to npm's flat layout for visibility while pnpm still
# maintains version isolation under .pnpm/. Same effect as
# --shamefully-hoist but declarative.
public-hoist-pattern[]=*
