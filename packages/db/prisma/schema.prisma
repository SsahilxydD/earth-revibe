generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// USER & AUTH
// ==========================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String?   @unique
  passwordHash  String    @default("")
  firstName     String
  lastName      String
  avatar        String?
  role          UserRole  @default(CUSTOMER)
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  phoneVerified Boolean   @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  addresses         Address[]
  orders            Order[]
  reviews           Review[]
  wishlistItems     WishlistItem[]
  cart              Cart?
  loyaltyPoints     Int              @default(0)
  loyaltyHistory    LoyaltyTransaction[]
  loyaltyRedemptions LoyaltyRedemption[]
  referralCode      String?          @unique
  referralsMade     Referral[]       @relation("Referrer")
  referredBy        Referral?        @relation("Referee")
  supportTickets    SupportTicket[]
  ticketMessages    TicketMessage[]
  refreshTokens     RefreshToken[]
  notifications     Notification[]
  orderNotes        OrderNote[]
  adminDevices      AdminDevice[]
  whatsappInbound   WhatsAppInboundMessage[]
  backInStockSubs   BackInStockSubscription[]
  dropSubscription  DropSubscription?
  dropAlertSends    DropAlertSend[]

  @@map("users")
}

enum UserRole {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
  SUPPORT_STAFF
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String   @db.VarChar(15)
  codeHash  String
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone, verified, expiresAt])
  @@map("otp_codes")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
  @@map("password_reset_tokens")
}

// Expo push tokens for the admin mobile app. One user can have multiple
// devices (phone + tablet). Service uses these to fan out new-order push
// notifications alongside Discord/WhatsApp/email channels.
model AdminDevice {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expoPushToken  String   @unique
  platform       String   @default("android")
  appVersion     String?
  lastSeenAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([userId])
  @@map("admin_devices")
}

model Address {
  id         String  @id @default(cuid())
  userId     String?
  user       User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String  @default("Home")
  fullName   String
  phone      String
  line1      String
  line2      String?
  city       String
  state      String
  pinCode    String
  isDefault  Boolean @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  orders     Order[]

  @@index([userId])
  @@map("addresses")
}

// ==========================================
// PRODUCTS & CATEGORIES
// ==========================================

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  products         Product[]
  productCategories ProductCategory[]

  @@index([parentId])
  @@map("categories")
}

model ProductCategory {
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([productId, categoryId])
  @@index([categoryId])
  @@map("product_categories")
}

model HomepageSection {
  id        String   @id @default(cuid())
  label     String
  href      String
  imageUrl  String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("homepage_sections")
}

model Product {
  id              String        @id @default(cuid())
  name            String
  slug            String        @unique
  description     String        @db.Text
  shortDescription String?
  price           Decimal       @db.Decimal(10, 2)
  compareAtPrice  Decimal?      @db.Decimal(10, 2)
  material        String?
  careInstructions String?      @db.Text
  seoTitle        String?
  seoDescription  String?       @db.Text
  seoKeywords     String?
  returnsInfo     String?
  shippingInfo    String?
  origin          String?
  composition     String?
  measurements    String?
  fabricWeight    String?
  fit             String?
  printType       String?
  washInstructions String?
  status          ProductStatus @default(DRAFT)
  isFeatured      Boolean       @default(false)
  vibes           String[]      @default([])
  categoryId      String
  category        Category      @relation(fields: [categoryId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  images            ProductImage[]
  variants          ProductVariant[]
  reviews           Review[]
  wishlistItems     WishlistItem[]
  tags              ProductTag[]
  productCategories ProductCategory[]

  @@index([categoryId])
  @@index([status])
  @@index([slug])
  @@map("products")
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  publicId  String  @default("")
  altText   String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)

  @@index([productId])
  @@map("product_images")
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku       String  @unique
  size      String
  color     String  @default("")
  colorHex  String?
  price     Decimal? @db.Decimal(10, 2)
  stock     Int     @default(0)
  lowStockThreshold Int @default(5)
  barcode   String?
  weight    Decimal? @db.Decimal(10, 2)
  weightUnit String? @default("g")
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cartItems  CartItem[]
  orderItems OrderItem[]

  backInStockSubs BackInStockSubscription[]

  @@unique([productId, size, color])
  @@index([productId])
  @@index([sku])
  @@map("product_variants")
}

model Tag {
  id       String       @id @default(cuid())
  name     String       @unique
  slug     String       @unique
  products ProductTag[]

  @@map("tags")
}

model ProductTag {
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@index([tagId])
  @@map("product_tags")
}

// ==========================================
// CART
// ==========================================

model Cart {
  id                       String     @id @default(cuid())
  userId                   String     @unique
  user                     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items                    CartItem[]
  abandonedEmailSentAt     DateTime?
  // Most recent WhatsApp recovery message id Meta returned. Used by the
  // /api/v1/webhooks/whatsapp handler to clear `abandonedEmailSentAt` if Meta
  // later reports the message as failed — closes the loop on accepted-but-undelivered.
  lastRecoveryMessageId    String?    @db.VarChar(255)
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt

  @@index([lastRecoveryMessageId])
  @@map("carts")
}

model CartItem {
  id        String         @id @default(cuid())
  cartId    String
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  quantity  Int            @default(1)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([cartId, variantId])
  @@index([cartId])
  @@index([variantId])
  @@map("cart_items")
}

model GuestAbandonedCart {
  id                    String   @id @default(cuid())
  email                 String
  firstName             String?
  items                 Json     // [{ variantId, productName, slug, price, quantity }]
  cartTotal             Float    @default(0)
  emailSent             Boolean  @default(false)
  // Reserved for symmetry with Cart — guests don't have phones today, but if
  // we ever capture phone via the popup we'll want the same webhook closure.
  lastRecoveryMessageId String?  @db.VarChar(255)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([email])
  @@index([lastRecoveryMessageId])
  @@map("guest_abandoned_carts")
}

/// Persistent log of every Meta WhatsApp delivery-status event we receive on
/// the /api/v1/webhooks/whatsapp endpoint. Source of truth for "did this
/// template actually reach the user" — Meta's 200 OK on send only means
/// "accepted by Meta", not delivered. Useful for audits and for the
/// abandoned-cart auto-retry loop (failure events clear the sent flag).
model WhatsAppMessageEvent {
  id                   String    @id @default(cuid())
  messageId            String    @db.VarChar(255)
  waId                 String?   @db.VarChar(20)
  status               String    @db.VarChar(20) // queued | sent | delivered | read | failed
  /// PR 8: template + variant key for A/B funnel analytics. Set at send time
  /// on the `queued` row, then copied onto subsequent webhook event rows so
  /// dashboard queries can group by (templateKey, variantKey, status) without
  /// a join. Null for older events that predate variant tracking.
  templateKey          String?   @db.VarChar(64)
  variantKey           String?   @db.VarChar(64)
  errorCode            Int?
  errorTitle           String?   @db.VarChar(255)
  errorMessage         String?
  conversationId       String?   @db.VarChar(64)
  conversationCategory String?   @db.VarChar(32)
  pricingModel         String?   @db.VarChar(16)
  pricingCategory      String?   @db.VarChar(32)
  rawPayload           Json
  eventAt              DateTime
  receivedAt           DateTime  @default(now())

  @@index([messageId])
  @@index([waId])
  @@index([status, eventAt])
  @@index([eventAt])
  @@index([templateKey, variantKey, status])
  @@map("whatsapp_message_events")
}

/// CRM template-variants registry. Each row defines a Meta-approved template
/// name plus a weight, grouped under a logical templateKey (e.g. all variants
/// of the abandoned-cart recovery message share templateKey
/// `ABANDONED_CART_RECOVERY`). At send time the API picks one variant by
/// weighted random selection from active rows for the given templateKey, sends
/// via that variant's templateName, and tags the resulting event with the
/// variantKey for funnel analytics.
///
/// Only the templateName column reaches Meta — body text and parameters are
/// fixed by Meta's approval. Adjust performance via weight, not content.
model WhatsAppTemplateVariant {
  id           String   @id @default(cuid())
  templateKey  String   @db.VarChar(64) // e.g. ABANDONED_CART_RECOVERY
  variantKey   String   @db.VarChar(64) // e.g. v1, v2, holiday-2026, …
  templateName String   @db.VarChar(255) // Meta-approved template name (the actual API payload)
  /// Human-readable preview of the body shown in CRM editor. Not sent to Meta.
  bodyPreview  String?
  /// Weighted random selection across the active set for the same templateKey.
  /// Sum of weights for active variants doesn't have to be 100; the picker
  /// normalises. A 0-weight variant never fires (alternative to isActive=false).
  weight       Int      @default(1)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([templateKey, variantKey])
  @@index([templateKey, isActive])
  @@map("whatsapp_template_variants")
}

/// Inbound WhatsApp messages from customers — replies to our outbound
/// templates, support requests, etc. Captured from the same /webhooks/whatsapp
/// endpoint that handles delivery statuses; PR 6 of the CRM migration.
///
/// userId is soft-mapped: we resolve it at write time by matching the
/// inbound `fromWaId` to a User.phone (digits-only). Nullable because plenty
/// of inbound messages come from people who aren't registered users yet.
model WhatsAppInboundMessage {
  id          String   @id @default(cuid())
  messageId   String   @unique @db.VarChar(255) // Meta's message id — dedupe key
  fromWaId    String   @db.VarChar(20) // sender's wa.me id (digits-only phone)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  messageType String   @db.VarChar(32) // text | image | audio | video | document | sticker | location | contacts | interactive | reaction | unknown
  text        String? // text body if messageType=text or interactive button reply
  mediaUrl    String? // Meta media URL (short-lived; download to Cloudflare if we want to keep it)
  repliedTo   String? @db.VarChar(255) // the messageId we sent that this is a reply to (Meta's context.id)
  rawPayload  Json
  receivedAt  DateTime @default(now())

  @@index([userId])
  @@index([fromWaId])
  @@index([receivedAt])
  @@index([repliedTo])
  @@map("whatsapp_inbound_messages")
}

/// CRM engagement rules — declarative escalation ladder.
///
/// PR 7: when a customer reads our outbound message but doesn't act on it,
/// fire an action after `delayHours`. v1 supports two safe action types
/// (manual-outreach flag, transactional email). WhatsApp template send was
/// deliberately omitted: the Meta fair-use guard rail that killed the
/// broadcast UIs (see feedback_meta_fair_use.md memory) extends to any
/// cron-driven template send.
model EngagementRule {
  id            String                   @id @default(cuid())
  name          String
  trigger       EngagementRuleTrigger
  delayHours    Int
  actionType    EngagementRuleActionType
  /// Schema varies by actionType:
  /// - FLAG_FOR_MANUAL_OUTREACH: { reason: string }
  /// - SEND_EMAIL: { subject: string, body: string }
  actionPayload Json
  isActive      Boolean                  @default(false)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  fires         EngagementRuleFire[]

  @@index([isActive, trigger])
  @@map("engagement_rules")
}

/// One row per (rule, target) pair that has already fired. The unique key
/// is the dedupe primitive — the cron evaluator skips targets that already
/// have a fire row for this rule, so re-running the cron is safe.
model EngagementRuleFire {
  id         String         @id @default(cuid())
  ruleId     String
  rule       EngagementRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  targetType String         @db.VarChar(32) // 'cart' | 'guest_cart' (+ more as triggers grow)
  targetId   String
  firedAt    DateTime       @default(now())
  /// Best-effort note for the CRM/audit log: what the cron observed when
  /// it fired (e.g. "read at 2026-05-06T..., no order in 24h").
  context    Json?

  @@unique([ruleId, targetType, targetId])
  @@index([ruleId])
  @@index([firedAt])
  @@map("engagement_rule_fires")
}

enum EngagementRuleTrigger {
  CART_ABANDONED_READ_NO_PURCHASE
}

enum EngagementRuleActionType {
  FLAG_FOR_MANUAL_OUTREACH
  SEND_EMAIL
}

/// CRM customer segments — saved cohort definitions for dashboard filters
/// and (later) for scoping engagement rules. PR 9.
///
/// `definition` holds a Zod-validated query DSL — see
/// customer-segment.schema.ts in @earth-revibe/shared. v1 supports a flat
/// list of (field, op, value) filters ANDed together.
///
/// `memberCount` is the result of the most recent evaluation; rebuilt
/// nightly by cron and on-demand via the CRM "Refresh" button. We do NOT
/// cache the actual user-id list yet — for v1 it's recomputed on demand
/// from the segment definition. Cheaper than maintaining a sync, and the
/// dashboard only reads the count.
model CustomerSegment {
  id              String    @id @default(cuid())
  name            String
  definition      Json
  memberCount     Int       @default(0)
  lastEvaluatedAt DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isActive])
  @@map("customer_segments")
}

/// Back-in-stock notify-me subscriptions (PR 10). When a variant's stock
/// goes from 0 to >0, the API sends a WhatsApp utility template to every
/// user with a non-notified row for that variant, then sets notifiedAt.
///
/// One subscription per (user, variant). Re-subscribing after a previous
/// notification updates `notifiedAt=null` so the user is queued for the
/// next restock cycle.
model BackInStockSubscription {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variantId   String
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  notifiedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([userId, variantId])
  @@index([variantId, notifiedAt])
  @@index([userId])
  @@map("back_in_stock_subscriptions")
}

/// New-drop marketing alert subscriptions. Distinct from BackInStockSubscription
/// (utility category) — Meta classifies drop alerts as marketing, so the
/// posture is stricter: explicit opt-in, frequency cap, daily marketing-send
/// budget, easy unsubscribe. See docs/plans/2026-05-06-new-drop-alerts-design.md.
model DropSubscription {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  optInAt         DateTime  @default(now())
  /// Most recent drop-alert send timestamp. Frequency cap (≤1 / 7d) compares against this.
  lastNotifiedAt  DateTime?
  /// Set when the user clicks the unsubscribe link or replies STOP via WhatsApp.
  /// Non-null = paused. Re-opt-in clears it AND writes a fresh optInAt.
  unsubscribedAt  DateTime?
  /// Single-purpose token for the WhatsApp unsubscribe deep-link
  /// (https://earthrevibe.com/u/<token>). Rotated on each opt-in.
  unsubToken      String    @unique @default(cuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([unsubscribedAt, lastNotifiedAt])
  @@map("drop_subscriptions")
}

/// Audit log of every drop alert sent. Compliance + frequency-cap enforcement.
model DropAlertSend {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// The product whose release triggered this alert (the carousel hero).
  productId   String
  /// Meta template + variant used (joins to whatsapp_message_events).
  templateKey String   @db.VarChar(64)
  variantKey  String   @db.VarChar(64)
  /// Meta's outbound message id — joins to whatsapp_message_events for status.
  messageId   String?  @unique @db.VarChar(255)
  sentAt      DateTime @default(now())

  @@index([userId, sentAt])
  @@index([productId, sentAt])
  @@map("drop_alert_sends")
}

/// Daily marketing-send budget tracker. One row per day per Asia/Kolkata
/// calendar day. Drop dispatcher reads/increments transactionally to enforce
/// the per-day marketing cap WITHOUT eating utility headroom.
model MarketingSendBudget {
  id        String   @id @default(cuid())
  /// YYYY-MM-DD in Asia/Kolkata. Unique — one row per day.
  day       String   @unique @db.VarChar(10)
  sentCount Int      @default(0)
  cap       Int      @default(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("marketing_send_budgets")
}

// ==========================================
// ORDERS & PAYMENTS
// ==========================================

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])
  guestEmail      String?
  addressId       String
  address         Address       @relation(fields: [addressId], references: [id])
  status          OrderStatus   @default(PLACED)
  subtotal        Decimal       @db.Decimal(10, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(10, 2)
  shippingAmount  Decimal       @default(0) @db.Decimal(10, 2)
  taxAmount       Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal       @db.Decimal(10, 2)
  loyaltyPointsUsed   Int       @default(0)
  loyaltyPointsEarned Int       @default(0)
  discountCodeId  String?
  discountCode    DiscountCode? @relation(fields: [discountCodeId], references: [id])
  shiprocketOrderId    Int?
  shiprocketShipmentId Int?
  awbCode              String?
  courierName          String?
  trackingUrl          String?
  /// Last time we refreshed shipment status from Shiprocket. Drives the
  /// "synced N min ago" badge in the admin orders list and lets us tell
  /// stale rows apart from genuinely-unchanged ones. Stamped on every
  /// successful tracking call regardless of whether the status changed.
  lastShipmentSyncAt   DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  items              OrderItem[]
  payment            Payment?
  statusHistory      OrderStatusHistory[]
  notes              OrderNote[]
  returnRequest      ReturnRequest?
  trackingActivities OrderTrackingActivity[]

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([addressId])
  @@index([discountCodeId])
  @@index([lastShipmentSyncAt])
  @@map("orders")
}

/// One row per Shiprocket tracking event for an order. Persisted on every
/// refresh so the customer tracking page can render history when Shiprocket
/// is unreachable, and so the admin has an auditable timeline beyond just
/// OrderStatusHistory (which only records OUR status transitions).
model OrderTrackingActivity {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  /// When the carrier reports this event happened (not when we fetched it).
  occurredAt DateTime
  /// Shiprocket's `sr-status-label` field — e.g. "Out For Delivery", "In Transit".
  status    String
  /// Free-text activity description from Shiprocket (e.g. "Shipment Picked Up").
  activity  String?
  /// City or hub name where the event occurred.
  location  String?
  createdAt DateTime @default(now())

  @@index([orderId, occurredAt])
  @@unique([orderId, occurredAt, status])
  @@map("order_tracking_activities")
}

enum OrderStatus {
  PLACED
  CONFIRMED
  PROCESSING
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED
}

model OrderItem {
  id        String         @id @default(cuid())
  orderId   String
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  quantity  Int
  unitPrice Decimal        @db.Decimal(10, 2)
  totalPrice Decimal       @db.Decimal(10, 2)
  productName    String
  productImage   String?
  variantSize    String
  variantColor   String

  @@index([orderId])
  @@index([variantId])
  @@map("order_items")
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  note      String?
  changedBy String?
  createdAt DateTime    @default(now())

  @@index([orderId])
  @@map("order_status_history")
}

model OrderNote {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String   @db.Text
  isInternal Boolean @default(true)
  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([userId])
  @@map("order_notes")
}

model Payment {
  id                  String        @id @default(cuid())
  orderId             String        @unique
  order               Order         @relation(fields: [orderId], references: [id])
  razorpayOrderId     String        @unique
  razorpayPaymentId   String?       @unique
  razorpaySignature   String?
  amount              Decimal       @db.Decimal(10, 2)
  currency            String        @default("INR")
  status              PaymentStatus @default(PENDING)
  method              PaymentMethod?
  refundId            String?
  refundAmount        Decimal?      @db.Decimal(10, 2)
  failureReason       String?
  paidAt              DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([razorpayOrderId])
  @@map("payments")
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  UPI
  CARD
  NETBANKING
  WALLET
  EMI
  COD
}

// ==========================================
// RETURNS
// ==========================================

model ReturnRequest {
  id           String       @id @default(cuid())
  orderId      String       @unique
  order        Order        @relation(fields: [orderId], references: [id])
  reason       String       @db.Text
  status       ReturnStatus @default(REQUESTED)
  adminNote    String?      @db.Text
  refundAmount Decimal?     @db.Decimal(10, 2)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("return_requests")
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  PICKED_UP
  RECEIVED
  REFUND_INITIATED
  COMPLETED
}

// ==========================================
// REVIEWS
// ==========================================

model Review {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  rating     Int
  title      String?
  content    String?  @db.Text
  isVerified Boolean  @default(false)
  isApproved Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
  @@map("reviews")
}

// ==========================================
// WISHLIST
// ==========================================

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("wishlist_items")
}

// ==========================================
// DISCOUNTS
// ==========================================

model DiscountCode {
  id               String       @id @default(cuid())
  code             String       @unique
  description      String?
  type             DiscountType
  value            Decimal      @db.Decimal(10, 2)
  minOrderValue    Decimal?     @db.Decimal(10, 2)
  maxDiscountAmount Decimal?    @db.Decimal(10, 2)
  usageLimit       Int?
  usageCount       Int          @default(0)
  perUserLimit     Int          @default(1)
  // Codes minted from a loyalty-points redemption are scoped to one specific
  // user so the redeeming customer can't share the code with others. Null
  // means the code is globally redeemable (the existing public-coupon case).
  userId           String?
  applicableCategories String[]
  applicableProducts   String[]
  isActive         Boolean      @default(true)
  startsAt         DateTime
  expiresAt        DateTime
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  orders           Order[]
  redemption       LoyaltyRedemption?

  @@index([code])
  @@index([userId])
  @@map("discount_codes")
}

enum DiscountType {
  PERCENTAGE
  FLAT
  BUY_X_GET_Y
  FREE_SHIPPING
}

// ==========================================
// LOYALTY & REFERRALS
// ==========================================

model LoyaltyTransaction {
  id          String                 @id @default(cuid())
  userId      String
  user        User                   @relation(fields: [userId], references: [id])
  type        LoyaltyTransactionType
  points      Int
  description String
  orderId     String?
  // When the points from this EARNED/BONUS txn stop being usable. Null means
  // never (e.g. REDEEMED/EXPIRED/ADJUSTED rows don't have their own expiry).
  expiresAt   DateTime?
  // Set when the expiry cron sweeps this row; prevents double-expiring.
  expiredAt   DateTime?
  createdAt   DateTime               @default(now())

  @@index([userId])
  @@index([expiresAt, expiredAt])
  @@map("loyalty_transactions")
}

enum LoyaltyTransactionType {
  EARNED
  REDEEMED
  BONUS
  EXPIRED
  ADJUSTED
}

// Email-gated redemption of loyalty points. Customer emails support → manager
// creates a row here with the requested amount → manager clicks "Approve" →
// points are deducted and a single-use, user-scoped DiscountCode is issued.
model LoyaltyRedemption {
  id             String                  @id @default(cuid())
  userId         String
  user           User                    @relation(fields: [userId], references: [id])
  pointsAmount   Int
  status         LoyaltyRedemptionStatus @default(PENDING)
  notes          String?
  approvedBy     String?
  approvedAt     DateTime?
  // The single-use DiscountCode we minted when approved. Null while PENDING.
  discountCodeId String?                 @unique
  discountCode   DiscountCode?           @relation(fields: [discountCodeId], references: [id])
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([userId])
  @@index([status])
  @@map("loyalty_redemptions")
}

enum LoyaltyRedemptionStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model LoyaltyConfig {
  id                  String  @id @default(cuid())
  pointsPerRupee      Decimal @db.Decimal(10, 4)
  pointRedemptionValue Decimal @db.Decimal(10, 4)
  welcomeBonus        Int     @default(0)
  reviewBonus         Int     @default(0)
  birthdayBonus       Int     @default(0)
  minRedeemPoints     Int     @default(100)
  isActive            Boolean @default(true)
  updatedAt           DateTime @updatedAt

  @@map("loyalty_config")
}

model Referral {
  id           String         @id @default(cuid())
  referrerId   String
  referrer     User           @relation("Referrer", fields: [referrerId], references: [id])
  refereeId    String         @unique
  referee      User           @relation("Referee", fields: [refereeId], references: [id])
  status       ReferralStatus @default(PENDING)
  referrerReward Int          @default(0)
  refereeReward  Int          @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([referrerId])
  @@map("referrals")
}

enum ReferralStatus {
  PENDING
  SIGNED_UP
  CONVERTED
}

model ReferralConfig {
  id              String  @id @default(cuid())
  referrerReward  Int     @default(100)
  refereeReward   Int     @default(50)
  requirePurchase Boolean @default(true)
  isActive        Boolean @default(true)
  updatedAt       DateTime @updatedAt

  @@map("referral_config")
}

// ==========================================
// BLOG / CMS
// ==========================================

model BlogPost {
  id            String         @id @default(cuid())
  title         String
  slug          String         @unique
  excerpt       String?
  content       String         @db.Text
  featuredImage String?
  authorId      String
  status        BlogPostStatus @default(DRAFT)
  publishedAt   DateTime?
  scheduledAt   DateTime?
  metaTitle     String?
  metaDescription String?
  readTime      Int?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  categories    BlogPostCategory[]
  tags          BlogPostTag[]

  @@index([slug])
  @@index([status])
  @@map("blog_posts")
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
}

model BlogCategory {
  id    String             @id @default(cuid())
  name  String             @unique
  slug  String             @unique
  posts BlogPostCategory[]

  @@map("blog_categories")
}

model BlogPostCategory {
  postId     String
  post       BlogPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  categoryId String
  category   BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
  @@index([categoryId])
  @@map("blog_post_categories")
}

model BlogTag {
  id    String        @id @default(cuid())
  name  String        @unique
  slug  String        @unique
  posts BlogPostTag[]

  @@map("blog_tags")
}

model BlogPostTag {
  postId String
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tagId  String
  tag    BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
  @@map("blog_post_tags")
}

// ==========================================
// SUPPORT TICKETS
// ==========================================

model SupportTicket {
  id         String         @id @default(cuid())
  ticketNumber String       @unique
  userId     String
  user       User           @relation(fields: [userId], references: [id])
  subject    String
  category   String
  status     TicketStatus   @default(OPEN)
  priority   TicketPriority @default(MEDIUM)
  assignedTo String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  messages   TicketMessage[]

  @@index([userId])
  @@index([status])
  @@map("support_tickets")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model TicketMessage {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  content   String        @db.Text
  attachment String?
  createdAt DateTime      @default(now())

  @@index([ticketId])
  @@index([userId])
  @@map("ticket_messages")
}

// ==========================================
// NOTIFICATIONS
// ==========================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

enum NotificationType {
  ORDER_CONFIRMED
  ORDER_SHIPPED
  ORDER_DELIVERED
  ORDER_CANCELLED
  RETURN_UPDATE
  TICKET_REPLY
  LOYALTY_EARNED
  REFERRAL_REWARD
  LOW_STOCK
  PROMOTION
}

// ==========================================
// STORE SETTINGS
// ==========================================

model StoreSettings {
  id                  String  @id @default(cuid())
  storeName           String  @default("Earth Revibe")
  logo                String?
  contactEmail        String?
  contactPhone        String?
  socialInstagram     String?
  socialFacebook      String?
  socialTwitter       String?
  freeShippingThreshold Decimal? @db.Decimal(10, 2)
  gstRate             Decimal @default(18) @db.Decimal(5, 2)
  returnWindowDays    Int     @default(7)
  checkoutConfig      Json?
  shippingConfig      Json?
  updatedAt           DateTime @updatedAt

  @@map("store_settings")
}

model ShippingZone {
  id        String  @id @default(cuid())
  name      String
  states    String[]
  rate      Decimal  @db.Decimal(10, 2)
  minDays   Int
  maxDays   Int
  isActive  Boolean  @default(true)

  @@map("shipping_zones")
}

model PendingCheckout {
  id                String   @id @default(cuid())
  orderNumber       String   @unique
  userId            String?
  guestEmail        String?
  razorpayOrderId   String   @unique
  discountCode      String?
  loyaltyPointsToUse Int     @default(0)
  subtotal          Decimal  @db.Decimal(10, 2)
  discountAmount    Decimal  @db.Decimal(10, 2) @default(0)
  loyaltyDiscount   Decimal  @db.Decimal(10, 2) @default(0)
  itemsJson         String
  stockReserved     Boolean  @default(false)
  reservedAt        DateTime?
  createdAt         DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("pending_checkouts")
}

model IdempotencyKey {
  id        String   @id @default(cuid())
  key       String   @unique
  userId    String
  status    String   // PROCESSING, COMPLETED, FAILED
  endpoint  String
  response  Json?
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([key, userId])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

// ==========================================
// TRAVEL CIRCLE APPLICATIONS
// ==========================================
// Submitted from the /apply-for-trip-form route on the storefront after
// a user completes the 14-screen WhatsApp-OTP-gated flow. Reviewed manually.

model TravelApplication {
  id                String                    @id @default(cuid())
  applicationNumber String                    @unique // e.g. "ER-2026-0042"
  userId            String? // optional — filled when the OTP step created/linked a User
  phone             String                    @db.VarChar(15)
  // Nullable at DB level to accommodate pre-email-field rows; new submissions
  // are required to provide email via the Zod schema validation.
  email             String?
  name              String
  age               Int
  city              String
  instagram         String
  travelerType      String // chill | party | explorer | mix
  whyJoin           String                    @db.Text
  pastTravel        String // yes | no
  tripPrefs         String[] // mountains | beaches | weekend | luxury
  meetBefore        String // yes | maybe | no
  curated           String // yes | no
  status            TravelApplicationStatus   @default(PENDING)
  reviewNotes       String?                   @db.Text
  reviewedAt        DateTime?
  // Tracks when applicant was last notified of a status decision — prevents
  // duplicate approval/rejection emails + WhatsApps if admin re-clicks.
  notifiedAt        DateTime?
  notifiedStatus    TravelApplicationStatus?
  // Tracks when the applicant-facing receipt acknowledgement (email +
  // WhatsApp) was sent on submission. Used to gate the admin backfill so
  // we never send the same "we got your application" twice.
  receivedNotifiedAt DateTime?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([phone])
  @@index([userId])
  @@index([status, createdAt])
  @@map("travel_applications")
}

enum TravelApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  WAITLISTED
}
