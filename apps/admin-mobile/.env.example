# Expo public env vars are inlined at build time. Anything sensitive
# stays on the API side. Use EAS Secrets for production builds.

# Base URL for the API. Local dev points to Railway; for LAN testing on a
# physical device, swap to your machine's LAN IP + port.
EXPO_PUBLIC_API_URL=https://earth-revibeapi-production.up.railway.app/api/v1
