# ============================================
# Earth Revibe API — Production Environment
# ============================================
# Copy this file and fill in your actual values.
# NEVER commit the filled-in version to git.

NODE_ENV=production
PORT=5000

# ---- Database (your existing hosted PostgreSQL) ----
DATABASE_URL=postgresql://user:password@host:5432/earth_revibe?sslmode=require
DIRECT_URL=postgresql://user:password@host:5432/earth_revibe?sslmode=require

# ---- JWT Secrets (generate with: openssl rand -hex 32) ----
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ---- Razorpay ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---- Cloudflare Images ----
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_IMAGES_API_TOKEN=

# ---- CORS Origins (your Vercel deployments) ----
FRONTEND_URL=https://storefront-sahilxyds-projects.vercel.app
ADMIN_URL=https://admin-sahilxyds-projects.vercel.app

# ---- Email (optional — transactional emails) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# ---- Shiprocket (optional — shipping integration) ----
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_PINCODE=110001
