# API — Environment Variables
# Copy to .env and fill in values

# Server
PORT=3002
NODE_ENV=development

# Database
DATABASE_URL=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Frontend URLs (CORS)
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# Sentry
SENTRY_DSN=

# Storefront ISR revalidation (server->server ping after admin homepage edits).
# Must match the storefront's REVALIDATION_SECRET. Unset = pages refresh hourly.
STOREFRONT_REVALIDATION_SECRET=
STOREFRONT_URLS=http://localhost:3000
