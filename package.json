{
  "name": "earth-revibe",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo test",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:api": "vitest run --config tests/api/vitest.config.ts",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "db:migrate": "turbo db:migrate",
    "db:migrate:deploy": "turbo db:migrate:deploy",
    "db:migrate:status": "turbo db:migrate:status",
    "db:seed": "turbo db:seed",
    "prepare": "husky || true",
    "claw": "node scripts/claw.js",
    "claw:frontend": "node scripts/claw.js frontend",
    "claw:admin": "node scripts/claw.js admin",
    "claw:api": "node scripts/claw.js api"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@playwright/test": "^1.51.0",
    "eslint": "^9.28.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "prettier": "^3.5.0",
    "turbo": "^2.8.13",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.34.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.10",
      "protobufjs@>=7.0.0 <7.5.6": ">=7.5.6",
      "axios@>=1.0.0 <1.16.0": ">=1.16.0",
      "picomatch@>=2.0.0 <4.0.4": ">=4.0.4",
      "fast-uri@<3.1.2": ">=3.1.2",
      "path-to-regexp@>=4.0.0 <8.4.0": ">=8.4.0"
    }
  }
}
