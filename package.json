{
  "name": "earth-revibe",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo test",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:api": "vitest run --config tests/api/vitest.config.ts",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "db:seed": "turbo db:seed",
    "prepare": "husky || true",
    "claw": "node scripts/claw.js",
    "claw:frontend": "node scripts/claw.js frontend",
    "claw:admin": "node scripts/claw.js admin",
    "claw:api": "node scripts/claw.js api"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@playwright/test": "^1.51.0",
    "eslint": "^9.28.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "prettier": "^3.5.0",
    "turbo": "^2.8.13",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.34.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.10",
      "@xmldom/xmldom": ">=0.8.13",
      "ajv": ">=8.18.0",
      "axios": ">=1.15.2",
      "brace-expansion@1": "^1.1.13",
      "brace-expansion@2": "^2.0.3",
      "diff": ">=8.0.3",
      "dompurify": ">=3.4.1",
      "follow-redirects": ">=1.16.0",
      "form-data": ">=4.0.4",
      "minimatch": ">=5.1.7",
      "next": ">=15.5.15",
      "nanoid": ">=3.3.8",
      "node-forge": ">=1.3.2",
      "nodemailer": ">=8.0.4",
      "path-to-regexp": ">=8.4.0",
      "picomatch": ">=4.0.4",
      "postcss": ">=8.5.10",
      "protobufjs": ">=7.5.5",
      "tar": ">=7.5.7",
      "uuid": ">=14.0.0",
      "vite": ">=7.3.2",
      "yaml": ">=2.8.3"
    }
  }
}
